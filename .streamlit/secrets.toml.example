# Ejemplo de configuracion para Streamlit Cloud
# Copia este archivo como secrets.toml y completa tus credenciales
# O configura los secrets en Streamlit Cloud Dashboard

[connections.snowflake]
account = "TU_CUENTA_SNOWFLAKE"
user = "TU_USUARIO"
password = "TU_PASSWORD"
warehouse = "COMPUTE_WH"
database = "AIRBNB"
schema = "RAW"
